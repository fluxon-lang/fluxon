# Database Schema Definitions for WhatsApp AI Ops
# Quill treats this as executable DDL

use pkg::db

fn init_schema(db) {
  db.exec("
    CREATE TABLE IF NOT EXISTS users (
      id SERIAL PRIMARY KEY,
      phone TEXT UNIQUE NOT NULL,
      name TEXT,
      api_token TEXT,
      llm_config JSONB DEFAULT '{}'::jsonb,
      created_at TIMESTAMP DEFAULT NOW()
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS customers (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      phone TEXT NOT NULL,
      name TEXT,
      address TEXT,
      delivery_day INT DEFAULT 0,
      created_at TIMESTAMP DEFAULT NOW(),
      UNIQUE(business_id, phone)
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS products (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      name TEXT NOT NULL,
      price DECIMAL(10,2) NOT NULL,
      category TEXT,
      available INT DEFAULT 1,
      created_at TIMESTAMP DEFAULT NOW(),
      UNIQUE(business_id, name)
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS orders (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      customer_id INT NOT NULL REFERENCES customers(id),
      status TEXT DEFAULT 'pending',
      delivery_date DATE,
      total_price DECIMAL(10,2),
      created_at TIMESTAMP DEFAULT NOW(),
      confirmed_at TIMESTAMP,
      delivered_at TIMESTAMP
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS order_items (
      id SERIAL PRIMARY KEY,
      order_id INT NOT NULL REFERENCES orders(id),
      product_id INT NOT NULL REFERENCES products(id),
      qty INT NOT NULL,
      price_at_order DECIMAL(10,2)
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS messages (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      customer_phone TEXT NOT NULL,
      direction TEXT,
      body TEXT,
      media_url TEXT,
      created_at TIMESTAMP DEFAULT NOW()
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS ai_interactions (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      customer_phone TEXT NOT NULL,
      intent TEXT,
      confidence DECIMAL(3,2),
      tokens_used INT,
      cost DECIMAL(10,4),
      latency_ms INT,
      tool_calls JSONB DEFAULT '[]'::jsonb,
      created_at TIMESTAMP DEFAULT NOW()
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS scheduled_routes (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      delivery_date DATE NOT NULL,
      customers JSONB,
      status TEXT DEFAULT 'pending',
      created_at TIMESTAMP DEFAULT NOW(),
      UNIQUE(business_id, delivery_date)
    )
  ")

  db.exec("
    CREATE TABLE IF NOT EXISTS proactive_outreach (
      id SERIAL PRIMARY KEY,
      business_id INT NOT NULL REFERENCES users(id),
      customer_id INT NOT NULL REFERENCES customers(id),
      delivery_date DATE,
      sent_at TIMESTAMP,
      response_text TEXT,
      responded_at TIMESTAMP,
      reason TEXT
    )
  ")

  db.exec("CREATE INDEX IF NOT EXISTS idx_customers_business ON customers(business_id)")
  db.exec("CREATE INDEX IF NOT EXISTS idx_products_business ON products(business_id)")
  db.exec("CREATE INDEX IF NOT EXISTS idx_orders_business ON orders(business_id)")
  db.exec("CREATE INDEX IF NOT EXISTS idx_orders_customer ON orders(customer_id)")
  db.exec("CREATE INDEX IF NOT EXISTS idx_ai_interactions_business ON ai_interactions(business_id)")
  db.exec("CREATE INDEX IF NOT EXISTS idx_messages_business ON messages(business_id)")
}

# Export for use in main.quill
{init_schema: init_schema}
