-- whatsapp.nol — WhatsApp provider adapter (Green API / Meta Cloud API compatible)

-- Send a WhatsApp message via the configured provider
fn send(to_phone, text, wa_token)
  let provider = env.get("WA_PROVIDER", "greenapi")

  if provider == "greenapi"
    let instance = env.WA_INSTANCE_ID
    let resp = http.post(
      "https://api.greenapi.com/waInstance{instance}/sendMessage/{wa_token}",
      {
        body: {
          chatId: "{to_phone}@c.us",
          message: text
        }
      }
    )
    if resp.status != 200
      log.error "WhatsApp send failed: {resp.body}"
      return {ok: no, error: resp.body}
    return {ok: yes, id: resp.body.idMessage}

  if provider == "meta"
    let resp = http.post(
      "https://graph.facebook.com/v18.0/{env.WA_PHONE_NUMBER_ID}/messages",
      {
        headers: {"Authorization": "Bearer {wa_token}"},
        body: {
          messaging_product: "whatsapp",
          to: to_phone,
          type: "text",
          text: {body: text}
        }
      }
    )
    if resp.status != 200
      log.error "Meta WhatsApp send failed: {resp.body}"
      return {ok: no, error: resp.body}
    return {ok: yes, id: resp.body.messages[0].id}

  log.error "Unknown WA_PROVIDER: {provider}"
  return {ok: no, error: "unknown provider"}
